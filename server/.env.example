# ── Server ───────────────────────────────────────────────
PORT=8787
# Comma-separated list of allowed client origins for CORS
CLIENT_ORIGIN=http://localhost:5173

# ── Kapruka MCP (public free tier — no auth) ─────────────
KAPRUKA_MCP_URL=https://mcp.kapruka.com/mcp

# ── Azure OpenAI (GPT-5.2) ───────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
# The *deployment name* of your GPT-5.2 model in Azure (not the model id)
AZURE_OPENAI_DEPLOYMENT=gpt-5.2
AZURE_OPENAI_API_VERSION=2024-10-21

# ── Display ──────────────────────────────────────────────
# Default currency for prices shown to the user (LKR, USD, GBP, AUD, CAD, EUR)
DEFAULT_CURRENCY=USD
