# ── Server ───────────────────────────────────────────────
PORT=8787
# Comma-separated list of allowed client origins for CORS
CLIENT_ORIGIN=http://localhost:5173

# ── Kapruka MCP (public free tier — no auth) ─────────────
KAPRUKA_MCP_URL=https://mcp.kapruka.com/mcp

# ── Google AI Studio (Gemini, OpenAI-compatible) ─────────
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=<your-google-ai-studio-key>
# Primary model, with automatic fallback when it's rate-limited. Free-tier daily
# quotas differ a lot — gemini-2.5-flash is ~20 requests/day, gemini-2.5-flash-lite ~1000/day.
GOOGLE_MODEL=gemini-2.5-flash
GOOGLE_FALLBACK_MODEL=gemini-2.5-flash-lite
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# ── Display ──────────────────────────────────────────────
# Default currency for prices shown to the user (LKR, USD, GBP, AUD, CAD, EUR)
DEFAULT_CURRENCY=USD
